    {
      "parameters": {
        "jsCode": "// Group signals by Company Domain.\n// Return only companies that have 3+ signals within the last 21 days.\n\nconst items = $input.all();\nconst now = new Date();\nconst cutoff = new Date(now.getTime() - 21 * 24 * 60 * 60 * 1000); // 21 days ago\n\nconst groups = {};\n\nfor (const item of items) {\n  const domain  = (item.json['Company Domain'] || '').trim().toLowerCase();\n  const dateStr = item.json['Date'] || '';\n  const date    = new Date(dateStr);\n\n  // Skip rows with no domain or dates older than 21 days\n  if (!domain || date < cutoff) continue;\n\n  if (!groups[domain]) {\n    groups[domain] = {\n      domain,\n      name: item.json['Company Name'] || '',\n      signals: [],\n      types: new Set()\n    };\n  }\n\n  groups[domain].signals.push(item.json['Signal Summary'] || '');\n  groups[domain].types.add(String(item.json['Signal Type'] || ''));\n}\n\n// Only keep clusters with 3+ signals AND at least one anchor signal (type 2 or 5)\n// Anchor: Signal 2 = G2 review (forecast miss/surprise churn) — highest direct USP connection\n// Anchor: Signal 5 = earnings/investor statement citing churn or NRR\n// Rationale: job postings and LinkedIn posts alone are too noisy to justify enrichment spend.\n// Requiring an anchor grounds the cluster in verifiable evidence of the pain QuadSci solves.\nconst clusters = Object.values(groups)\n  .filter(g => {\n    if (g.signals.length < 3) return false;\n    const hasAnchor = [...g.types].some(t => t === '2' || t === '5');\n    return hasAnchor;\n  })\n  .map(g => ({\n    json: {\n      company_domain: g.domain,\n      company_name: g.name,\n      signal_count: g.signals.length,\n      signal_types: [...g.types].sort().join(','),\n      signal_summaries: g.signals.join(' | ')\n    }\n  }));\n\nif (clusters.length === 0) {\n  // Return a special no-op item so the workflow doesn't error\n  return [{ json: { __no_clusters: true } }];\n}\n\nreturn clusters;"
      },
