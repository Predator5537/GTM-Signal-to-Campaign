      ],
      "alwaysOutputData": true,
      "credentials": {
        "googleSheetsOAuth2Api": {
          "id": "mCitxoRY2r1cdcjh",
          "name": "Google Sheets OAuth2"
        }
      },
      "notes": "alwaysOutputData=true is critical: when Scored Accounts is empty (first-ever run), Sheets read returns 0 items and would kill the downstream chain. This forces at least one item out so the dedup Code node executes."
    },
    {
      "parameters": {
        "jsCode": "// Check which clusters already exist in Scored Accounts (dedup).\n//\n// Why we pull cluster data from $('Code — Detect Signal Clusters') rather than $input:\n// - $input here is downstream of 'Sheets — Read Scored Accounts', which contains existing\n//   scored-account rows, NOT the cluster payload we care about.\n// - The cluster payload lives upstream at 'Code — Detect Signal Clusters' and must be\n//   reached by name, otherwise it's lost when Sheets node replaces input with its rows.\n//\n// Why we filter empty items from existing rows:\n// - 'Sheets — Read Scored Accounts' has alwaysOutputData=true so it emits an item even when\n//   the sheet is empty. Without filtering, an empty item would falsely register as a row.\n\nconst clusters = $('Code — Detect Signal Clusters').all()\n  .filter(c => c.json && !c.json.__no_clusters && c.json.company_domain);\n\nif (clusters.length === 0) {\n  return [];\n}\n\nconst existingRows = $('Sheets — Read Scored Accounts').all()\n  .filter(r => r.json && r.json['Company Domain']);\nconst existingDomains = new Set(\n  existingRows.map(r => String(r.json['Company Domain']).trim().toLowerCase())\n);\n\nreturn clusters.map(c => ({\n  json: {\n    ...c.json,\n    already_exists: existingDomains.has(String(c.json.company_domain).trim().toLowerCase())\n  }\n}));"
      },
