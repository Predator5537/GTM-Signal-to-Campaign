      "notes": "Reads Clay-enriched buyer contacts from the separate Buyer Contacts tab. Clay cannot write back to its source sheet, so Find Person results are exported to this tab. Joined with Scored Accounts on Company Domain in the merge node below."
    },
    {
      "parameters": {
        "jsCode": "// Merge Buyer Contacts into Scored Accounts rows, joined on Company Domain.\n//\n// Clay cannot write enrichment results back to its source Google Sheet.\n// Workaround: Clay exports Find Person results to a separate 'Buyer Contacts' tab.\n// This node joins them here in n8n before the rest of WF4 runs.\n//\n// Domain normalization strips protocol, www prefix, and path/query suffixes so\n// that 'https://gong.io/', 'www.gong.io', and 'gong.io' all match each other.\n// Without this, Clay-enriched contacts with slightly different domain formats\n// silently fail to join and buyer fields remain empty downstream.\n\nfunction normalizeDomain(d) {\n  if (!d) return '';\n  return String(d).trim().toLowerCase()\n    .replace(/^https?:\\/\\//, '')\n    .replace(/^www\\./, '')\n    .replace(/[/?#].*$/, '');\n}\n\nconst accounts = $('Sheets — Get Enriched Accounts').all();\nconst contacts = $('Sheets — Get Buyer Contacts').all();\n\n// Build a lookup map: normalized domain → first matching contact\nconst contactMap = {};\nfor (const c of contacts) {\n  const domain = normalizeDomain(c.json['Company Domain']);\n  if (domain && !contactMap[domain]) contactMap[domain] = c.json;\n}\n\n// Merge contact fields into each account row\nconst merged = accounts.map(a => {\n  const domain  = normalizeDomain(a.json['Company Domain']);\n  const contact = contactMap[domain] || {};\n  return {\n    json: {\n      ...a.json,\n      'Buyer Name':  a.json['Buyer Name']  || contact['Buyer Name']  || '',\n      'Buyer Title': a.json['Buyer Title'] || contact['Buyer Title'] || '',\n      'Buyer Email': a.json['Buyer Email'] || contact['Buyer Email'] || ''\n    }\n  };\n});\n\nreturn merged;"
      },
      "id": "e9c4d2fb-ced2-46ea-bbe8-a4472644bda8",
      "name": "Code — Merge Buyer Contacts",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -1632,
        208
      ],
      "notes": "Joins Scored Accounts + Buyer Contacts on Company Domain. Prefers values already in the account row (manual overrides), falls back to Clay-enriched contact fields. Output feeds the IF guard as if buyer fields were always on the account row."
    },
