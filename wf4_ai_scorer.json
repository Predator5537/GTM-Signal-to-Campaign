    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "function normalizeDomain(d) {\n  if (!d) return '';\n  return String(d).trim().toLowerCase()\n    .replace(/^https?:\\/\\//, '')\n    .replace(/^www\\./, '')\n    .replace(/[/?#].*$/, '');\n}\n\nfunction sanitize(val) {\n  if (val === null || val === undefined) return '';\n  return String(val)\n    .replace(/\\\"/g, \"'\")\n    .replace(/\\r?\\n/g, ' ')\n    .trim();\n}\n\nconst current = $input.item.json;\nconst domain = normalizeDomain(current['Company Domain'] || current.company_domain || '');\n\nconst allAccounts = $('Code — Merge Buyer Contacts').all();\nconst account = allAccounts.find(\n  a => normalizeDomain(a.json['Company Domain']) === domain\n)?.json || {};\n\nreturn {\n  json: {\n    'Company Name':     sanitize(account['Company Name']),\n    'Company Domain':   account['Company Domain'] || current['Company Domain'] || '',\n    'Employee Count':   account['Employee Count'] || '',\n    'Funding Stage':    sanitize(account['Funding Stage']),\n    'Estimated ARR':    sanitize(account['Estimated ARR']),\n    'CS Headcount':     account['CS Headcount'] || '',\n    'Tech Stack':       sanitize(account['Tech Stack']),\n    'Signal Types':     sanitize(account['Signal Types']),\n    'Signal Summaries': sanitize(account['Signal Summaries']),\n    'Buyer Name':       sanitize(account['Buyer Name']),\n    'Buyer Title':      sanitize(account['Buyer Title']),\n    'Buyer Email':      account['Buyer Email'] || ''\n  }\n};"
      },
      "id": "c3f39779-adb8-4cf1-b64d-560af52649c8",
      "name": "Code — Sanitize Account for Scoring",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -1136,
        112
      ],
      "notes": "Sanitizes text fields before JSON interpolation in the OpenRouter scoring node. Now runs runOnceForEachItem so every account is independently processed — prevents silent item-drop if multiple accounts reach this node. Returns single json object (not array) as required by per-item mode."
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://openrouter.ai/api/v1/chat/completions",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "openRouterApi",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"moonshotai/kimi-k2-0905\",\n  \"temperature\": 0,\n  \"response_format\": { \"type\": \"json_object\" },\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"You are a deterministic GTM scoring engine. Score the account only from the provided fields. Return ONLY one valid JSON object with exactly these fields: firmographic_score, signal_score, tech_score, total_score, tier, reasoning. firmographic_score must be an integer from 0 to 40. signal_score must be an integer from 0 to 45. tech_score must be an integer from 0 to 15. total_score must equal the sum of those three scores and must be an integer from 0 to 100. tier must be exactly one of: Tier 1, Tier 2, Tier 3, Discard. reasoning must be one sentence, 20 words maximum. If data is missing or unclear, score conservatively and do not guess. Do not include any text outside the JSON object.\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": \"Score this account:\\\\n\\\\nCompany: {{ $json['Company Name'] }}\\\\nDomain: {{ $json['Company Domain'] }}\\\\nEmployees: {{ $json['Employee Count'] }}\\\\nFunding Stage: {{ $json['Funding Stage'] }}\\\\nEstimated ARR: {{ $json['Estimated ARR'] }}\\\\nCS Headcount: {{ $json['CS Headcount'] }}\\\\nTech Stack: {{ $json['Tech Stack'] }}\\\\nSignals fired: {{ $json['Signal Types'] }}\\\\nSignal summaries: {{ $json['Signal Summaries'] }}\\\\n\\\\nSCORING RUBRIC:\\\\n\\\\nFIRMOGRAPHIC FIT:\\\\n- Employees 500+: 20pts | 200-499: 15pts | 100-199: 8pts | under 100: 0pts\\\\n- Funding Stage Public or Series C or later: 15pts | Series B: 10pts | Series A or earlier or unknown: 0pts\\\\n- ARR $100M+: 15pts | $50M-$99M: 8pts | under $50M or unknown: 0pts\\\\n- CS team 10+: 10pts | 5-9: 5pts | under 5 or unknown: 0pts\\\\n- Compute the raw firmographic subtotal from the rules above\\\\n- firmographic_score = min(raw firmographic subtotal, 40)\\\\n\\\\nSIGNAL STRENGTH:\\\\n- Public earnings or investor statement mentioning churn: 20pts\\\\n- G2 review mentioning forecast or surprise churn: 15pts\\\\n- CRO or VP CS LinkedIn post about NRR pain: 15pts\\\\n- Director or above CS or RevOps hire announced: 10pts\\\\n- Job posting for CS platform migration or Gainsight or ChurnZero: 10pts\\\\n- Each additional distinct signal beyond the first 3: +5pts\\\\n- Only count signals explicitly supported by Signals fired or Signal summaries\\\\n- Do not count the same signal twice\\\\n- Compute the raw signal subtotal from the rules above\\\\n- signal_score = min(raw signal subtotal, 45)\\\\n\\\\nTECH STACK FIT:\\\\n- Uses Gainsight or ChurnZero: 10pts\\\\n- Uses Segment, Amplitude, Mixpanel, or Heap: 5pts\\\\n- Uses Salesforce: 5pts\\\\n- Only award points for tools explicitly present in Tech Stack\\\\n- Compute the raw tech subtotal from the rules above\\\\n- tech_score = min(raw tech subtotal, 15)\\\\n\\\\nTOTAL SCORE:\\\\n- total_score = firmographic_score + signal_score + tech_score\\\\n- total_score must be 0-100 only\\\\n\\\\nTIER ASSIGNMENT:\\\\n- Tier 1: total_score 80-100\\\\n- Tier 2: total_score 60-79\\\\n- Tier 3: total_score 40-59\\\\n- Discard: total_score below 40\\\\n\\\\nReturn ONLY a valid JSON object in this exact format:\\\\n{\\\\n  \\\\\\\"firmographic_score\\\\\\\": 0,\\\\n  \\\\\\\"signal_score\\\\\\\": 0,\\\\n  \\\\\\\"tech_score\\\\\\\": 0,\\\\n  \\\\\\\"total_score\\\\\\\": 0,\\\\n  \\\\\\\"tier\\\\\\\": \\\\\\\"Discard\\\\\\\",\\\\n  \\\\\\\"reasoning\\\\\\\": \\\\\\\"\\\\\\\"\\\\n}\\\\n\\\\nBefore responding, verify:\\\\n- all score fields are integers\\\\n- no category exceeds its cap\\\\n- total_score equals the sum of the three category scores\\\\n- tier matches total_score exactly\"\n    }\n  ]\n}",
        "options": {}
      },
      "id": "03538c29-9998-440c-ad62-8e1dc5855b4e",
      "name": "OpenRouter — Score Account",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        -976,
        112
      ],
      "credentials": {
        "httpHeaderAuth": {
          "id": "uM6SVfqA6c18NyzX",
          "name": "OpenRouter QuadSci"
        },
        "openRouterApi": {
          "id": "sU3T9CpIOkDnxbSj",
          "name": "OpenRouter API"
        }
      }
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "// Parse OpenRouter JSON response, clamp scores to rubric caps,\n// recompute total score, and derive tier deterministically.\n\nconst response = $input.item.json;\nconst raw = response?.choices?.[0]?.message?.content || '{}';\n\nlet scores;\ntry {\n  scores = typeof raw === 'string' ? JSON.parse(raw) : raw;\n} catch (e) {\n  scores = {\n    firmographic_score: 0,\n    signal_score: 0,\n    tech_score: 0,\n    total_score: 0,\n    tier: 'Discard',\n    reasoning: 'Parse error — check OpenRouter response format'\n  };\n}\n\nfunction clampInt(value, min, max) {\n  const n = Number(value);\n  if (!Number.isFinite(n)) return min;\n  return Math.max(min, Math.min(Math.round(n), max));\n}\n\n// Clamp each scoring bucket to rubric max\nconst firmographic = clampInt(scores.firmographic_score, 0, 40);\nconst signal = clampInt(scores.signal_score, 0, 45);\nconst tech = clampInt(scores.tech_score, 0, 15);\n\n// Recompute total from clamped buckets\nconst total = firmographic + signal + tech;\n\n// Derive tier from recomputed total\nlet tier = 'Discard';\nif (total >= 80) tier = 'Tier 1';\nelse if (total >= 60) tier = 'Tier 2';\nelse if (total >= 40) tier = 'Tier 3';\n\n// Get the domain we just marked Scoring In Progress\nconst domain = $('Sheets — Mark Scoring In Progress').item.json['Company Domain'];\n\n// Find the matching merged account row\nconst allAccounts = $('Code — Merge Buyer Contacts').all();\nconst account = allAccounts.find(\n  a => String(a.json['Company Domain']).trim().toLowerCase() === String(domain).trim().toLowerCase()\n)?.json || {};\n\nreturn {\n  json: {\n    company_domain:     account['Company Domain'] || domain,\n    company_name:       account['Company Name'] || '',\n    employee_count:     account['Employee Count'] || '',\n    funding_stage:      account['Funding Stage'] || '',\n    estimated_arr:      account['Estimated ARR'] || '',\n    tech_stack:         account['Tech Stack'] || '',\n    cs_headcount:       account['CS Headcount'] || '',\n    signal_types:       account['Signal Types'] || '',\n    signal_summaries:   account['Signal Summaries'] || '',\n    buyer_name:         account['Buyer Name'] || '',\n    buyer_title:        account['Buyer Title'] || '',\n    buyer_email:        account['Buyer Email'] || '',\n    firmographic_score: firmographic,\n    signal_score:       signal,\n    tech_score:         tech,\n    total_score:        total,\n    tier:               tier,\n    reasoning:          scores.reasoning || ''\n  }\n};"
      },
      "id": "2555cf02-fa1a-4f08-b8af-76a64f552fa3",
      "name": "Code — Parse Score Result",
      "type": "n8n-nodes-base.code",
