    {
      "parameters": {
        "jsCode": "function normalizeDomain(d) {\n  if (!d) return '';\n  return String(d).trim().toLowerCase()\n    .replace(/^https?:\\/\\//, '')\n    .replace(/^www\\./, '')\n    .replace(/[/?#].*$/, '');\n}\n\nconst current = $input.first().json;\nconst domain = normalizeDomain(\n  current.company_domain || current['Company Domain'] || ''\n);\n\n// Recover the full scored object from Code — Parse Score Result when the\n// immediate input is just the Sheets writeback payload.\nconst parsedItems = $('Code — Parse Score Result').all();\nconst scored = parsedItems.find(\n  i => normalizeDomain(i.json.company_domain || i.json['Company Domain']) === domain\n)?.json || current;\n\nconst allContacts = $('Sheets — Get Buyer Contacts').all();\nconst matching = allContacts.filter(c =>\n  normalizeDomain(c.json['Company Domain']) === domain\n);\n\nif (matching.length === 0) {\n  return [{ json: { ...scored } }];\n}\n\nreturn matching.map(c => ({\n  json: {\n    ...scored,\n    buyer_name:  c.json['Buyer Name']  || scored.buyer_name  || '',\n    buyer_title: c.json['Buyer Title'] || scored.buyer_title || '',\n    buyer_email: c.json['Buyer Email'] || scored.buyer_email || ''\n  }\n}));"
      },
      "id": "76ac4ca4-6ee7-4d60-b8a3-a48cdf17573d",
      "name": "Code — Split Per Contact",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -80,
        0
      ],
      "notes": "Fan-out node: takes one scored account item and emits one item per matching buyer contact. The HTTP node downstream fires once per output item — one WF5 execution per contact, one email per person."
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://localhost:5678/webhook/generate-email-copy",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify($json) }}",
        "options": {}
      },
      "id": "1af71a4a-2d3c-46f9-b307-851eb8485c90",
      "name": "HTTP — Trigger WF5 Copy Generator",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        160,
        0
      ],
      "notes": "Fires once per item from Code — Split Per Contact. Uses $json (current per-contact item) — NOT a named node reference — so each call carries the correct buyer_name/title/email for that specific contact. WF5 must be ACTIVE before WF4 runs."
    }
